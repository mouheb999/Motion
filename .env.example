# Copy this file to `.env.local` and fill in real values.

# Inline Calendly booking widget. If unset, the CTA section shows a
# placeholder card explaining how to enable it.
# Example: https://calendly.com/your-handle/30min
NEXT_PUBLIC_CALENDLY_URL=

# WhatsApp number used by the floating button, hero CTA, and CTA section.
# Digits only, with country code (no `+`, no spaces).
NEXT_PUBLIC_WHATSAPP_NUMBER=21624146409
